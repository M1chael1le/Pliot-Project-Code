rules_version = '2';

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // DEVELOPMENT RULES - WARNING: DO NOT USE IN PRODUCTION
    // These rules allow anyone to read and write to your database.
    // We are using these temporarily because the portal does not have 
    // real Firebase Authentication setup yet.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

